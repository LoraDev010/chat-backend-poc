# Chat Backend - Environment Variables
# Copia este archivo a .env para configuración local

# Puerto del servidor (default: 3000)
PORT=3000

# Ambiente de ejecución (development | production | test)
NODE_ENV=development

# Ruta de la base de datos SQLite (default: ./rooms.db)
# Usa ':memory:' para base de datos en memoria (testing)
DB_PATH=./rooms.db

# CORS Origin permitido (default: *)
# En producción, especifica el dominio del frontend
CORS_ORIGIN=*
